{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://collabrix-lite.onrender.com/api/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "https://collabrix-lite.onrender.com/socket.io/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}